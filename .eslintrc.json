{
    "extends": ["next/core-web-vitals", "prettier"],
    "rules": {
        "@typescript-eslint/no-unused-vars": "off",
        "react/no-unescaped-entities": "off",
        "react/jsx-key": "off",
        "@next/next/no-img-element": "off",
        "react-hooks/rules-of-hooks": "error",
        "react-hooks/exhaustive-deps": "warn"
    }
}
